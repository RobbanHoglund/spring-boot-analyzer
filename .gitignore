target/
out/
bin/

*.class
*.jar
*.war
*.ear
*.nar

# Keep wrapper JARs if artifact JARs are ignored
!gradle/wrapper/gradle-wrapper.jar
!.mvn/wrapper/maven-wrapper.jar


